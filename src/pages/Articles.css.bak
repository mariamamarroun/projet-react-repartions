/* Page background + layout */
.articles-page {
  background: #0a0e14;
  min-height: 100vh;
  color: white;
  padding: 2rem;
  font-family: 'Helvetica Neue', Arial, sans-serif;
}

.top-space {
  height: 120px;
}

/* Search bar */
.header-search {
  display: flex;
  justify-content: center;
  margin-bottom: 2rem;
}

.header-search input {
  width: 60%;
  max-width: 800px;
  background: rgba(255,255,255,0.1);
  border: none;
  color: white;
  padding: 0.75rem 1rem 0.75rem 2.5rem;
  font-size: 1rem;
  border-radius: 0.5rem;
  background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg width='16' height='16' xmlns='http://www.w3.org/2000/svg'%3e%3cpath stroke='%23ffffff' stroke-width='2' d='M11 11l4 4M6.5 11a4.5 4.5 0 1 0 0-9 4.5 4.5 0 0 0 0 9z'/%3e%3c/svg%3e");
  background-repeat: no-repeat;
  background-position: 10px center;
}

/* Empty cart banner */
.empty-cart-banner {
  width: 80%;
  margin: 2rem auto;
  padding: 2rem;
  border-radius: 20px;

  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(12px);

  border: 1px solid rgba(0, 255, 255, 0.2);

  text-align: center;

  box-shadow: 0 0 25px rgba(0, 255, 255, 0.08);
}

.cart-icon {
  font-size: 2.5rem;
  margin-bottom: 0.5rem;
  color: #00ffff;
  text-shadow: 0 0 10px #00ffff;
}

.empty-cart-banner p {
  color: #00ffff;
  font-size: 1.1rem;
  letter-spacing: 1px;
}

/* Products horizontal row */
.products-row {
  display: flex;
  justify-content: center;
  gap: 1.5rem;
  margin-top: 2rem;
  flex-wrap: wrap;
}

/* Product card */
.product-card {
  width: 240px;
  background: #13152a;
  border-radius: 12px;
  overflow: hidden;
  transition: 0.3s;
  position: relative;
}

.product-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 0 20px rgba(0, 255, 255, 0.15);
}

.product-card img {
  width: 100%;
  display: block;
}

.product-info {
  padding: 1rem;
}

.product-info h3 {
  margin: 0;
  font-size: 1rem;
  font-weight: bold;
}

.product-info .price {
  color: #00ffff;
  text-shadow: 0 0 8px rgba(0,255,255,0.5);
  margin-top: 0.5rem;
  font-weight: 600;
}

.product-info .stock-badge {
  display: inline-block;
  padding: 0.25rem 0.75rem;
  border-radius: 999px;
  font-size: 0.75rem;
  margin-top: 0.5rem;
}

.stock-available {
  background: #0f3;
  box-shadow: 0 0 6px #0f3;
}

.stock-unavailable {
  background: #a00;
  opacity: 0.6;
}

.add-to-cart {
  position: absolute;
  bottom: 1rem;
  left: 50%;
  transform: translateX(-50%);
  background: #00d4ff;
  color: #000;
  padding: 0.5rem 1rem;
  border-radius: 0.5rem;
  cursor: pointer;
  opacity: 0;
  transition: opacity 0.2s;
}

.product-card:hover .add-to-cart {
  opacity: 1;
}

/* Cart summary */
.cart-summary {
  width: 80%;
  margin: 2rem auto;
  padding: 1rem;
  background: rgba(255,255,255,0.05);
  border-radius: 12px;
  backdrop-filter: blur(8px);
}

.cart-summary h2 {
  color: #00ffff;
  margin-bottom: 1rem;
}

.cart-item {
  display: flex;
  align-items: center;
  margin-bottom: 1rem;
}

.cart-item img {
  width: 40px;
  height: 40px;
  object-fit: cover;
  border-radius: 0.25rem;
  margin-right: 0.5rem;
}

.cart-item .info {
  flex: 1;
}

.cart-item .quantity {
  display: flex;
  align-items: center;
}

.cart-item .quantity button {
  background: none;
  border: 1px solid white;
  color: white;
  width: 20px;
  height: 20px;
  font-size: 1rem;
  line-height: 1;
  border-radius: 4px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 0.25rem;
}

.cart-item .remove {
  color: #f33;
  cursor: pointer;
  font-size: 1.2rem;
  margin-left: 0.5rem;
}

/* Responsive */
@media (max-width: 768px) {
  .header-search input {
    width: 90%;
  }
}
/* 🔥 CART PANEL */
.cart-panel {
  background: rgba(10,14,20,0.95);
  border-radius: 20px;
  padding: 20px;
  margin-bottom: 30px;
  backdrop-filter: blur(10px);
  border: 1px solid rgba(0,255,255,0.2);
  box-shadow: 0 0 20px rgba(0,255,255,0.1);
}

.cart-panel h2 {
  margin-bottom: 15px;
  color: #fff;
}

/* CART ITEMS */
.cart-item {
  display: flex;
  align-items: center;
  margin-bottom: 15px;
  gap: 10px;
}

.cart-item img {
  width: 50px;
  height: 50px;
  border-radius: 8px;
}

.cart-item .info {
  flex: 1;
}

.cart-item .title {
  font-size: 14px;
}

.cart-item .price {
  color: #00ffff;
}

/* QUANTITY */
.quantity button {
  background: transparent;
  border: 1px solid #00ffff;
  color: #00ffff;
  border-radius: 50%;
  width: 28px;
  height: 28px;
  cursor: pointer;
  transition: 0.2s;
}

.quantity button:hover {
  background: #00ffff;
  color: black;
}

/* REMOVE */
.remove {
  color: #ff4d4d;
  cursor: pointer;
  font-size: 18px;
}

/* FOOTER */
.cart-footer {
  margin-top: 20px;
  border-top: 1px solid rgba(255,255,255,0.1);
  padding-top: 15px;
}

.total-price {
  color: #00ffff;
  font-size: 20px;
  font-weight: bold;
  margin: 10px 0;
}

/* CHECKOUT BUTTON */
.checkout-btn {
  width: 100%;
  padding: 12px;
  background: #00ffff;
  border: none;
  border-radius: 10px;
  font-weight: bold;
  cursor: pointer;
  transition: 0.3s;
}

.checkout-btn:hover {
  box-shadow: 0 0 15px #00ffff;
}

/* DIM PRODUCTS WHEN CART ACTIVE */
.products-row.dimmed {
  opacity: 0.4;
}
/* 🔥 MODAL OVERLAY */
.order-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.7);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

/* 🔥 MODAL */
.order-modal {
  background: rgba(10,14,20,0.95);
  padding: 40px;
  border-radius: 20px;
  text-align: center;
  width: 400px;
  border: 1px solid rgba(0,255,255,0.3);
  box-shadow: 0 0 30px rgba(0,255,255,0.2);
  animation: fadeIn 0.4s ease;
}

/* ICON SUCCESS */
.success-icon {
  width: 80px;
  height: 80px;
  margin: 0 auto 20px;
  border-radius: 50%;
  background: rgba(0,255,100,0.1);
  color: #00ff88;
  font-size: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 20px rgba(0,255,100,0.4);
}

/* TITLE */
.order-modal h2 {
  color: #fff;
  margin-bottom: 10px;
}

/* TEXT */
.order-modal p {
  color: #00ffff;
  font-size: 14px;
  margin-bottom: 20px;
}

/* SUMMARY */
.order-summary {
  margin: 20px 0;
  padding: 15px;
  border-top: 1px solid rgba(255,255,255,0.1);
  border-bottom: 1px solid rgba(255,255,255,0.1);
}

/* ANIMATION */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}